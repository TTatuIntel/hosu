# HOSU Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

DB_HOST=localhost
DB_NAME=hosu_blog
DB_USER=root
DB_PASS=

# Payment Gateway – Flutterwave
# Sign up at https://dashboard.flutterwave.com to get your keys
# Test keys start with FLWSECK_TEST- and FLWPUBK_TEST-
# Live keys start with FLWSECK- and FLWPUBK-
FLW_SECRET_KEY=
FLW_PUBLIC_KEY=

# Set to true for local dev — simulates payment flow without real API keys
PAYMENT_TEST_MODE=true

# App
APP_ENV=development
APP_DOMAIN=hosu.or.ug

# SMTP Email (PHPMailer)
# For Gmail: enable "App Passwords" at https://myaccount.google.com/apppasswords
# For Mailtrap (testing): use smtp.mailtrap.io port 2525
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=infor@hosu.or.ug
SMTP_PASS=
SMTP_FROM=infor@hosu.or.ug
SMTP_FROM_NAME=HOSU
SMTP_ENCRYPTION=tls
