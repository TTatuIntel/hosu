# HOSU Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

DB_HOST=localhost
DB_NAME=hosu_blog
DB_USER=root
DB_PASS=
ADMIN_SEED_PASSWORD=ad@Hosu2026!

# Payment Gateway – Flutterwave
# Sign up at https://dashboard.flutterwave.com to get your keys
# Live keys start with FLWSECK- and FLWPUBK-
FLW_SECRET_KEY=
FLW_PUBLIC_KEY=

# App
APP_ENV=production
APP_DOMAIN=hosu.or.ug

# SMTP Email (PHPMailer) — Gmail SMTP sending FROM info@hosu.or.ug
#
# SETUP REQUIRED (one-time):
# 1. Enable 2-Step Verification on your Gmail:
#       https://myaccount.google.com/security
# 2. Generate an App Password (App name: HOSU Website):
#       https://myaccount.google.com/apppasswords
# 3. In Gmail > Settings > Accounts > "Send mail as" > add info@hosu.or.ug
#    Gmail sends a verification code to info@hosu.or.ug — enter it to confirm.
# 4. In your hosu.or.ug DNS panel, add/update the SPF TXT record:
#       v=spf1 include:_spf.google.com ~all
#
# SMTP_USER = your actual Gmail address (authentication only, not shown to recipients)
# SMTP_FROM = info@hosu.or.ug  (what recipients see — requires step 3 above)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tattuintel@gmail.com
SMTP_PASS=uzdxjshodlejpacu
SMTP_FROM=info@hosu.or.ug
SMTP_REPLY_TO=info@hosu.or.ug
SMTP_FROM_NAME=HOSU
SMTP_ENCRYPTION=tls
