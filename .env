# HOSU Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

DB_HOST=localhost
DB_NAME=hosu_blog
DB_USER=root
DB_PASS=
ADMIN_SEED_PASSWORD=ad@Hosu2026!

# Payment Gateway â€“ Flutterwave
# Sign up at https://dashboard.flutterwave.com to get your keys
# Live keys start with FLWSECK- and FLWPUBK-
FLW_SECRET_KEY=
FLW_PUBLIC_KEY=

# App
APP_ENV=production
APP_DOMAIN=hosu.or.ug

# SMTP Email (PHPMailer)
# For Gmail: enable "App Passwords" at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=infor@hosu.or.ug
SMTP_PASS=
SMTP_FROM=infor@hosu.or.ug
SMTP_REPLY_TO=infor@hosu.or.ug
SMTP_FROM_NAME=HOSU
SMTP_ENCRYPTION=tls
