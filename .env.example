# HOSU Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.

DB_HOST=localhost
DB_NAME=hosuweb_db
DB_USER=root
DB_PASS=
ADMIN_SEED_PASSWORD=ChangeMe@Hosu2026!

# Payment Gateway – Flutterwave (https://dashboard.flutterwave.com)
FLW_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxx
FLW_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxx

# Set to false for live Flutterwave processing — no simulated approvals
PAYMENT_TEST_MODE=false

# SMTP Email (PHPMailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=infor@hosu.or.ug
SMTP_PASS=
SMTP_FROM=infor@hosu.or.ug
SMTP_REPLY_TO=infor@hosu.or.ug
SMTP_FROM_NAME=HOSU
SMTP_ENCRYPTION=tls

# App
APP_ENV=development
APP_DOMAIN=hosu.or.ug
