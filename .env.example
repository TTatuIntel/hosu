# HOSU Environment Configuration
# Copy to .env on the server:  cp .env.example .env  then fill in real values.
# NEVER commit .env to git.

DB_HOST=localhost
DB_NAME=hosu_blog
DB_USER=hosu_user
DB_PASS=your_mysql_password_here
ADMIN_SEED_PASSWORD=ad@Hosu2026!

# Payment Gateway – PesaPal v3
# Dashboard: https://pay.pesapal.com/iframe/PesapalIframe/Index
# Sandbox:   https://cybqa.pesapal.com/pesapalv3
PESAPAL_CONSUMER_KEY=your_pesapal_consumer_key
PESAPAL_CONSUMER_SECRET=your_pesapal_consumer_secret
PESAPAL_ENV=production

# App
APP_ENV=production
APP_DOMAIN=hosu.or.ug

# SMTP (Gmail) — SMTP_USER = Gmail login; SMTP_FROM = info@hosu.or.ug (Send mail as)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=info@hosu.or.ug
SMTP_REPLY_TO=info@hosu.or.ug
SMTP_FROM_NAME=HOSU
SMTP_ENCRYPTION=tls
