# HOSU Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.

DB_HOST=localhost
DB_NAME=hosu_blog
DB_USER=root
DB_PASS=

# Payment Gateway – Flutterwave (https://dashboard.flutterwave.com)
FLW_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxx
FLW_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxx

# Set to true for local dev — simulates payment flow without real API keys
PAYMENT_TEST_MODE=true

# SMTP Email (PHPMailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=info@hosu.org
SMTP_FROM_NAME=HOSU
SMTP_ENCRYPTION=tls

# App
APP_ENV=development
APP_DOMAIN=hosu.org
