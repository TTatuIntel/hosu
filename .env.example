# HOSU Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.

DB_HOST=localhost
DB_NAME=hosuweb_db
DB_USER=root
DB_PASS=
ADMIN_SEED_PASSWORD=ChangeMe@Hosu2026!

# Payment Gateway – Flutterwave (https://dashboard.flutterwave.com)
# Live keys start with FLWSECK- and FLWPUBK-
FLW_SECRET_KEY=FLWSECK-xxxxxxxxxxxxxxxxxxxxxx
FLW_PUBLIC_KEY=FLWPUBK-xxxxxxxxxxxxxxxxxxxxxx

# SMTP Email (PHPMailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@hosu.or.ug
SMTP_PASS=
SMTP_FROM=info@hosu.or.ug
SMTP_REPLY_TO=info@hosu.or.ug
SMTP_FROM_NAME=HOSU
SMTP_ENCRYPTION=tls

# App
APP_ENV=production
APP_DOMAIN=hosu.or.ug
