# Force HTTPS
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteCond %{HTTP_HOST} !^localhost
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# Deny access to sensitive files
<FilesMatch "\.(env|env\.example|md)$">
    Require all denied
</FilesMatch>

# Deny access to env loader
<Files "env.php">
    Require all denied
</Files>

# Deny access to setup/seed scripts
<Files "setup_db.php">
    Require all denied
</Files>
<Files "seed_sample_data.php">
    Require all denied
</Files>
<Files "_tmp_check.php">
    Require all denied
</Files>

# Prevent directory listing
Options -Indexes

# Disable .htaccess file serving
<Files ".htaccess">
    Require all denied
</Files>
