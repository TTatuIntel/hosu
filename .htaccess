# Deny access to sensitive files
<FilesMatch "\.(env|env\.example|md)$">
    Require all denied
</FilesMatch>

# Deny access to env loader
<Files "env.php">
    Require all denied
</Files>

# Deny access to setup script
<Files "setup_db.php">
    Require all denied
</Files>
<Files "_tmp_check.php">
    Require all denied
</Files>

# Prevent directory listing
Options -Indexes

# Allow larger image uploads (hero photos, member documents)
<IfModule mod_php.c>
    php_value upload_max_filesize 16M
    php_value post_max_size 20M
</IfModule>
<IfModule mod_php7.c>
    php_value upload_max_filesize 16M
    php_value post_max_size 20M
</IfModule>
<IfModule mod_php8.c>
    php_value upload_max_filesize 16M
    php_value post_max_size 20M
</IfModule>

# Disable .htaccess file serving
<Files ".htaccess">
    Require all denied
</Files>
